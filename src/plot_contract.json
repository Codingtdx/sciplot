  "validation_rules": {
    "single_panel_axis_frame": {
      "label": "Single-panel axis frame alignment",
      "description": "Standard single-panel templates must share the same physical axis frame.",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "wide_nmr_horizontal_alignment": {
      "label": "Wide NMR left/right/bottom alignment",
      "description": "Wide NMR only requires the left, right, and bottom edges to share anchors with the standard single-panel frame.",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "wide_nmr_structure_reserve": {
      "label": "Wide NMR top structure reserve",
      "description": "Wide NMR must keep a reserved structure area at the top.",
      "severity": "error",
      "tolerance_mm": 1.0
    },
    "wide_nmr_segment_alignment": {
      "label": "Wide NMR segmented-axis alignment",
      "description": "Wide NMR segmented axes must share the same top and bottom bounds.",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "heatmap_main_frame": {
      "label": "Heatmap main-frame alignment",
      "description": "The heatmap main frame must share the same axis frame as standard single-panel plots.",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "heatmap_horizontal_colorbar": {
      "label": "Heatmap top horizontal colorbar",
      "description": "Heatmaps must use a top horizontal colorbar without squeezing the main frame.",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "heatmap_colorbar_inside_canvas": {
      "label": "Heatmap colorbar inside canvas",
      "description": "The heatmap colorbar and z label must stay fully inside the canvas.",
      "severity": "error",
      "tolerance_mm": 0.2
    },
    "non_blank_pdf": {
      "label": "Non-blank exported PDF",
      "description": "Every exported PDF must contain visible content and rasterize correctly.",
      "severity": "error"
    },
    "multi_output_bundle_notice": {
      "label": "Multi-output notice",
      "description": "Multi-output bundles should warn how many files will be exported.",
      "severity": "warning"
    },
    "dense_group_label_warning": {
      "label": "Dense group-label warning",
      "description": "Statistical plots should warn that x-axis labels may become crowded when many groups are present.",
      "severity": "warning"
    }
  }
}
