  "validation_rules": {
    "single_panel_axis_frame": {
      "label": "标准单图轴框对齐",
      "description": "标准单图模板必须共享同一物理轴框。",
      "severity": "error",
      "tolerance_mm": 0.05
    },
    "wide_nmr_horizontal_alignment": {
      "label": "wide NMR 左右底对齐",
      "description": "wide NMR 只要求左、右、底与标准单图共用锚点。",
      "severity": "error",
